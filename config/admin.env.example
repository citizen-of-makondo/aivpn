# Required: shared AIVPN config directory (contains clients.json and server.key)
AIVPN_CONFIG_DIR=/etc/aivpn

# Required: public VPN endpoint embedded into generated aivpn:// keys
AIVPN_SERVER_ADDR=vpn.example.com:443

# Required: single admin account
AIVPN_ADMIN_USER=admin
# IMPORTANT: in docker compose env files, escape each '$' as '$$'
# Example below is escaped for compose and will become a valid '$argon2id$...' value inside the container.
AIVPN_ADMIN_PASSWORD_HASH=$$argon2id$$v=19$$m=19456,t=2,p=1$$REPLACE_WITH_REAL_SALT$$REPLACE_WITH_REAL_HASH

# Required: at least 32 bytes
AIVPN_SESSION_SECRET=replace-with-long-random-secret-32-bytes-minimum

# Optional
AIVPN_ADMIN_BIND=0.0.0.0:8081
AIVPN_COOKIE_SECURE=true
AIVPN_LOGIN_RATE_LIMIT_PER_MINUTE=20
AIVPN_MUTATION_RATE_LIMIT_PER_MINUTE=120

# Used by deploy/admin/Caddyfile via docker compose env substitution
AIVPN_ADMIN_DOMAIN=admin.example.com
AIVPN_ADMIN_EMAIL=ops@example.com
